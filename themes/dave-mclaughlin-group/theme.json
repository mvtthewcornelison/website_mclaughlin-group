{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "primary",  "name": "Primary Red", "color": "#B20000" },
        { "slug": "primary-dark", "name": "Primary Red Dark", "color": "#7A0000" },
        { "slug": "black",    "name": "Black",       "color": "#0A0A0A" },
        { "slug": "gray-900", "name": "Gray 900",    "color": "#1A1A1A" },
        { "slug": "gray-700", "name": "Gray 700",    "color": "#3D3D3D" },
        { "slug": "gray-500", "name": "Gray 500",    "color": "#737373" },
        { "slug": "gray-300", "name": "Gray 300",    "color": "#BFBFBF" },
        { "slug": "gray-100", "name": "Gray 100",    "color": "#F2F2F2" },
        { "slug": "gray-50",  "name": "Gray 50",     "color": "#FAFAFA" },
        { "slug": "white",    "name": "White",       "color": "#FFFFFF" }
      ],
      "defaultPalette": false,
      "customDuotone": false,
      "defaultDuotone": false
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "sans",
          "name": "Sans",
          "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
        }
      ],
      "fontSizes": [
        { "slug": "small",    "size": "0.875rem", "name": "Small" },
        { "slug": "medium",   "size": "1rem",     "name": "Medium" },
        { "slug": "large",    "size": "1.25rem",  "name": "Large" },
        { "slug": "x-large",  "size": "2rem",     "name": "X-Large", "fluid": { "min": "1.5rem", "max": "2rem" } },
        { "slug": "xx-large", "size": "3.5rem",   "name": "XX-Large", "fluid": { "min": "2.25rem", "max": "3.5rem" } },
        { "slug": "display",  "size": "5.5rem",   "name": "Display",  "fluid": { "min": "3rem", "max": "5.5rem" } }
      ],
      "defaultFontSizes": false
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1280px"
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vh", "vw"]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--gray-50)",
      "text": "var(--wp--preset--color--black)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6",
      "fontWeight": "400"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--display)",
          "fontWeight": "700",
          "lineHeight": "1.05",
          "letterSpacing": "-0.02em"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)",
          "fontWeight": "700",
          "lineHeight": "1.1",
          "letterSpacing": "-0.015em"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "fontWeight": "600",
          "lineHeight": "1.2",
          "letterSpacing": "-0.01em"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--black)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "typography": {
          "fontWeight": "500",
          "letterSpacing": "0.02em",
          "fontSize": "var(--wp--preset--font-size--medium)"
        },
        "border": {
          "radius": "0"
        },
        "spacing": {
          "padding": {
            "top": "0.875rem",
            "bottom": "0.875rem",
            "left": "1.75rem",
            "right": "1.75rem"
          }
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--primary-dark)",
            "text": "var(--wp--preset--color--white)"
          }
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "fontWeight": "700",
          "letterSpacing": "-0.01em"
        }
      },
      "core/navigation": {
        "typography": {
          "fontWeight": "500",
          "fontSize": "var(--wp--preset--font-size--medium)",
          "letterSpacing": "0.01em"
        }
      }
    }
  }
}
